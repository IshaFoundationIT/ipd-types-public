{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"types": ["bun"],
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"declaration": true,
		"isolatedModules": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*.ts", "legacy/**/*.ts", "index.ts"],
	"exclude": ["node_modules", "dist"]
}
